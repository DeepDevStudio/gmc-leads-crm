import React, { useState, useEffect, useRef } from 'react';
import axios from 'axios';
import { getTemplates } from '../services/templateService';
import { getInterests } from '../services/interestService';

const BroadcastPage = () => {
    const [qrCode, setQrCode] = useState(null);
    const [whatsappNumber, setWhatsappNumber] = useState('');
    const [memberName, setMemberName] = useState('');
    const [showNamePrompt, setShowNamePrompt] = useState(false);
    const [isConnected, setIsConnected] = useState(false);
    const [statusMessage, setStatusMessage] = useState('');
    const [sessions, setSessions] = useState([]);
    const [messageLogs, setMessageLogs] = useState([]);
    const [loading, setLoading] = useState(false);
    const [templates, setTemplates] = useState([]);
    const [interests, setInterests] = useState([]);
    const [yatras, setYatras] = useState([]);
    const [selectedInterests, setSelectedInterests] = useState([]);
    const [selectedYatra, setSelectedYatra] = useState('');
    const [selectedTemplate, setSelectedTemplate] = useState('');
    const [customMessage, setCustomMessage] = useState('');
    const [targetGroup, setTargetGroup] = useState('Daily Reach');
    const [previewCount, setPreviewCount] = useState(0);
    const [previewCustomers, setPreviewCustomers] = useState([]);
    const [showPreview, setShowPreview] = useState(false);
    const [message, setMessage] = useState({ text: "", type: "" });
    const [teamMember, setTeamMember] = useState(
        JSON.parse(localStorage.getItem('user'))?.full_name || 
        JSON.parse(localStorage.getItem('user'))?.username || 
        'Unknown'
    );
    const [presetMessages, setPresetMessages] = useState([
        { id: 1, name: '🚀 Yatra Offer', message: 'Book your yatra now and get 10% off! Limited time offer. 🚀' },
        { id: 2, name: '🏔️ Haridwar Special', message: 'Special Haridwar yatra package starting at ₹999 only! Book now.' },
        { id: 3, name: '📞 Follow-up', message: 'Hi! We hope you enjoyed your yatra. Please share your feedback with us.' },
        { id: 4, name: '📢 Campaign Alert', message: 'New campaigns available! Check our latest offers and book your spot.' },
        { id: 5, name: '🎉 Festival Offer', message: 'Festival special! Get extra 5% off on all yatra bookings. Hurry up!' },
    ]);
    const [selectedPreset, setSelectedPreset] = useState('');
    const wsRef = useRef(null);
    const reconnectTimeout = useRef(null);

    useEffect(() => {
        loadSessions();
        loadMessageLogs();
        loadTemplates();
        loadInterests();
        loadYatras();
        connectWhatsApp();
        return () => {
            if (wsRef.current) {
                wsRef.current.close();
            }
            if (reconnectTimeout.current) {
                clearTimeout(reconnectTimeout.current);
            }
        };
    }, []);

    const connectWhatsApp = () => {
        try {
            const wsUrl = `ws://${window.location.hostname}:6001`;
            console.log('Connecting to WebSocket:', wsUrl);
            const ws = new WebSocket(wsUrl);
            wsRef.current = ws;

            ws.onopen = () => {
                setStatusMessage('Connected to WhatsApp service...');
            };

            ws.onmessage = (event) => {
                const data = JSON.parse(event.data);
                console.log('WhatsApp event:', data);

                if (data.type === 'qr') {
                    setQrCode(data.qr);
                    setStatusMessage('Scan QR code with your WhatsApp');
                } else if (data.type === 'authenticated') {
                    setQrCode(null);
                    setIsConnected(true);
                    setStatusMessage('WhatsApp Connected! ✅');
                    if (data.whatsapp_number) {
                        setWhatsappNumber(data.whatsapp_number);
                        checkWhatsAppNumber(data.whatsapp_number);
                    }
                } else if (data.type === 'disconnected') {
                    setIsConnected(false);
                    setStatusMessage('WhatsApp Disconnected. Reconnecting...');
                    reconnectTimeout.current = setTimeout(() => {
                        connectWhatsApp();
                    }, 5000);
                } else if (data.type === 'message_sent') {
                    setStatusMessage(`Message sent to ${data.recipient}`);
                    loadSessions();
                    loadMessageLogs();
                    showMessage(`Message sent to ${data.recipient}`, "success");
                } else if (data.type === 'error') {
                    setStatusMessage(`Error: ${data.message}`);
                    showMessage(`Error: ${data.message}`, "error");
                }
            };

            ws.onerror = () => {
                setStatusMessage('Connection error. Retrying...');
                setTimeout(() => {
                    connectWhatsApp();
                }, 3000);
            };

            ws.onclose = () => {
                setStatusMessage('Disconnected. Reconnecting...');
                setTimeout(() => {
                    connectWhatsApp();
                }, 3000);
            };
        } catch (error) {
            console.error('WebSocket connection error:', error);
            setStatusMessage('Could not connect to WhatsApp service');
        }
    };

    const checkWhatsAppNumber = async (number) => {
        try {
            const response = await axios.post('/api/whatsapp/check-number', {
                whatsapp_number: number
            });
            
            if (response.data.exists) {
                setMemberName(response.data.member_name);
                setIsConnected(true);
                setStatusMessage(`Welcome back, ${response.data.member_name}! ✅`);
            } else {
                setShowNamePrompt(true);
                setStatusMessage('New member! Please enter your name.');
            }
        } catch (error) {
            console.error('Error checking number:', error);
        }
    };

    const saveMemberName = async () => {
        if (!memberName.trim()) {
            alert('Please enter your name');
            return;
        }
        try {
            await axios.post('/api/whatsapp/save-member', {
                whatsapp_number: whatsappNumber,
                member_name: memberName,
                session_id: 'web_' + Date.now()
            });
            setShowNamePrompt(false);
            setIsConnected(true);
            setStatusMessage(`Welcome, ${memberName}! ✅`);
            loadSessions();
        } catch (error) {
            console.error('Error saving member:', error);
            alert('Failed to save member name');
        }
    };

    const loadSessions = async () => {
        try {
            const response = await axios.get('/api/whatsapp/sessions');
            setSessions(response.data || []);
        } catch (error) {
            console.error('Error loading sessions:', error);
        }
    };

    const loadMessageLogs = async () => {
        try {
            const response = await axios.get('/api/broadcast/logs');
            setMessageLogs(response.data || []);
        } catch (error) {
            console.error('Error loading message logs:', error);
        }
    };

    const loadTemplates = async () => {
        try {
            const data = await getTemplates();
            setTemplates(data.filter(t => t.status === 'Active'));
        } catch (error) {
            console.error('Error loading templates:', error);
        }
    };

    const loadInterests = async () => {
        try {
            const response = await axios.get('/api/interests');
            setInterests(response.data || []);
        } catch (error) {
            console.error('Error loading interests:', error);
            setInterests([]);
        }
    };

    const loadYatras = async () => {
        try {
            const response = await axios.get('/api/yatras');
            setYatras(response.data || []);
        } catch (error) {
            console.error('Error loading yatras:', error);
            setYatras([]);
        }
    };

    const showMessage = (text, type = "success") => {
        setMessage({ text, type });
        setTimeout(() => setMessage({ text: "", type: "" }), 3000);
    };

    const handlePresetSelect = (e) => {
        const presetId = e.target.value;
        setSelectedPreset(presetId);
        if (presetId) {
            const preset = presetMessages.find(p => p.id === parseInt(presetId));
            if (preset) {
                setCustomMessage(preset.message);
            }
        }
    };

    const handleInterestChange = (e) => {
        const value = e.target.value;
        if (!value || selectedInterests.includes(value)) return;
        setSelectedInterests([...selectedInterests, value]);
        updatePreview([...selectedInterests, value], selectedYatra);
    };

    const removeInterest = (interest) => {
        const updated = selectedInterests.filter((i) => i !== interest);
        setSelectedInterests(updated);
        updatePreview(updated, selectedYatra);
    };

    const handleYatraChange = (e) => {
        const value = e.target.value;
        setSelectedYatra(value);
        updatePreview(selectedInterests, value);
    };

    const updatePreview = async (interestsList, yatra) => {
        try {
            const response = await axios.post('/api/broadcast/preview', {
                interests: interestsList,
                group: targetGroup,
                yatra: yatra || ''
            });
            setPreviewCount(response.data.count || 0);
            setPreviewCustomers(response.data.customers || []);
        } catch (error) {
            console.error('Error fetching preview:', error);
        }
    };

    const getMessageText = () => {
        if (selectedTemplate) {
            const template = templates.find(t => t.id === parseInt(selectedTemplate));
            return template ? template.message : customMessage;
        }
        return customMessage;
    };

    const sendBroadcast = async () => {
        console.log('===== SEND BUTTON CLICKED =====');
        
        if (!isConnected) {
            showMessage('Please connect WhatsApp first', "error");
            return;
        }

        if (selectedInterests.length === 0 && !selectedYatra) {
            showMessage('Please select at least one interest or yatra', "error");
            return;
        }

        const messageText = getMessageText();
        if (!messageText) {
            showMessage('Please select a template or write a custom message', "error");
            return;
        }

        if (previewCount === 0) {
            showMessage('No customers found for the selected criteria', "error");
            return;
        }

        const confirmSend = window.confirm(
            `Send to ${previewCount} customers?\n\n` +
            `Interests: ${selectedInterests.join(', ') || 'All'}\n` +
            `Yatra: ${selectedYatra || 'All'}\n` +
            `Group: ${targetGroup}\n` +
            `Team Member: ${teamMember}`
        );
        if (!confirmSend) return;

        setLoading(true);
        try {
            const response = await axios.post('/api/broadcast/send', {
                interests: selectedInterests,
                yatra: selectedYatra || '',
                group: targetGroup,
                message: messageText,
                template_id: selectedTemplate || null,
                team_member: teamMember
            });
            
            showMessage(
                `✅ ${response.data.sent} sent, ${response.data.failed} failed`,
                response.data.failed > 0 ? "warning" : "success"
            );
            loadSessions();
            loadMessageLogs();
            setPreviewCount(0);
            setPreviewCustomers([]);
        } catch (error) {
            console.error('Error:', error);
            showMessage('Failed to send: ' + (error.response?.data?.error || error.message), "error");
        } finally {
            setLoading(false);
        }
    };

    const togglePreview = () => {
        setShowPreview(!showPreview);
        if (!showPreview && (selectedInterests.length > 0 || selectedYatra)) {
            updatePreview(selectedInterests, selectedYatra);
        }
    };

    const getStatusColor = (status) => {
        switch(status) {
            case 'Sent': return 'bg-green-100 text-green-700';
            case 'Failed': return 'bg-red-100 text-red-700';
            case 'Pending': return 'bg-yellow-100 text-yellow-700';
            default: return 'bg-gray-100 text-gray-600';
        }
    };

    return (
        <div className="p-6 max-w-7xl mx-auto">
            {message.text && (
                <div className={`p-4 rounded-xl mb-4 ${
                    message.type === "success" 
                        ? "bg-green-100 text-green-700 border border-green-200" 
                        : message.type === "warning"
                            ? "bg-yellow-100 text-yellow-700 border border-yellow-200"
                            : "bg-red-100 text-red-700 border border-red-200"
                }`}>
                    {message.text}
                </div>
            )}

            <div className="flex justify-between items-center mb-6">
                <div>
                    <h1 className="text-3xl font-bold text-gray-800">📱 WhatsApp Broadcast</h1>
                    <p className="text-gray-500 mt-1">Send messages to customers based on interests and yatras</p>
                </div>
                <div className="flex items-center gap-3">
                    <span className="text-sm text-gray-500">👤 {teamMember}</span>
                    <div className={`px-4 py-2 rounded-full text-sm font-medium ${
                        isConnected 
                            ? 'bg-green-100 text-green-700 border border-green-200' 
                            : 'bg-red-100 text-red-700 border border-red-200'
                    }`}>
                        {isConnected ? '✅ Connected' : '❌ Not Connected'}
                    </div>
                </div>
            </div>

            {statusMessage && (
                <div className={`p-4 rounded-xl mb-6 ${
                    statusMessage.includes('✅') 
                        ? 'bg-green-100 text-green-700 border border-green-200' 
                        : statusMessage.includes('❌') 
                            ? 'bg-red-100 text-red-700 border border-red-200' 
                            : 'bg-yellow-100 text-yellow-700 border border-yellow-200'
                }`}>
                    {statusMessage}
                </div>
            )}

            {qrCode && !isConnected && (
                <div className="bg-white rounded-2xl shadow-lg border border-gray-200 p-6 mb-6">
                    <div className="text-center">
                        <p className="text-sm text-gray-500 mb-4">Scan this QR code with WhatsApp</p>
                        <img src={qrCode} alt="WhatsApp QR Code" className="mx-auto max-w-sm" />
                    </div>
                </div>
            )}

            {showNamePrompt && whatsappNumber && (
                <div className="bg-white rounded-2xl shadow-lg border border-gray-200 p-6 mb-6">
                    <h2 className="text-xl font-bold mb-4">👋 Welcome New Member!</h2>
                    <p className="text-gray-600 mb-4">
                        WhatsApp number: <strong>{whatsappNumber}</strong>
                    </p>
                    <div className="flex gap-4">
                        <input
                            type="text"
                            placeholder="Enter your name"
                            value={memberName}
                            onChange={(e) => setMemberName(e.target.value)}
                            className="flex-1 border border-gray-300 p-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-yellow-400"
                        />
                        <button
                            onClick={saveMemberName}
                            className="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-xl font-semibold transition"
                        >
                            Save Name
                        </button>
                    </div>
                </div>
            )}

            {isConnected && memberName && (
                <div className="bg-green-50 border border-green-200 rounded-2xl p-4 mb-6">
                    <p className="text-green-700 font-semibold">
                        ✅ Connected as: {memberName}
                    </p>
                    <p className="text-sm text-gray-500 mt-1">
                        WhatsApp: {whatsappNumber}
                    </p>
                </div>
            )}

            <div className="bg-white rounded-2xl shadow-lg border border-gray-200 p-6 mb-6">
                <h2 className="text-xl font-bold mb-4">📤 Send Broadcast</h2>
                
                <div className="grid md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label className="block font-medium text-gray-700 mb-1">Target Interests</label>
                        <select
                            onChange={handleInterestChange}
                            className="w-full border border-gray-300 p-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-yellow-400"
                            value=""
                        >
                            <option value="">Select Interest</option>
                            {interests.map((interest) => (
                                <option key={interest.id} value={interest.interest_name}>
                                    {interest.interest_name}
                                </option>
                            ))}
                        </select>
                        <div className="flex flex-wrap gap-2 mt-2">
                            {selectedInterests.map((interest) => (
                                <div key={interest} className="bg-yellow-100 px-3 py-1 rounded-full text-sm flex items-center">
                                    {interest}
                                    <button
                                        type="button"
                                        onClick={() => removeInterest(interest)}
                                        className="ml-2 text-red-500 hover:text-red-700"
                                    >
                                        ✕
                                    </button>
                                </div>
                            ))}
                        </div>
                    </div>

                    <div>
                        <label className="block font-medium text-gray-700 mb-1">Target Yatra</label>
                        <select
                            value={selectedYatra}
                            onChange={handleYatraChange}
                            className="w-full border border-gray-300 p-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-yellow-400"
                        >
                            <option value="">All Yatras</option>
                            {yatras.map((yatra) => (
                                <option key={yatra.id} value={yatra.yatra_name}>
                                    {yatra.yatra_name}
                                </option>
                            ))}
                        </select>
                        {selectedYatra && (
                            <div className="mt-2 bg-blue-100 px-3 py-1 rounded-full text-sm inline-block">
                                📍 {selectedYatra}
                                <button
                                    type="button"
                                    onClick={() => {
                                        setSelectedYatra('');
                                        updatePreview(selectedInterests, '');
                                    }}
                                    className="ml-2 text-red-500 hover:text-red-700"
                                >
                                    ✕
                                </button>
                            </div>
                        )}
                    </div>
                </div>

                <div className="mb-4">
                    <label className="block font-medium text-gray-700 mb-1">Target Group</label>
                    <select
                        value={targetGroup}
                        onChange={(e) => {
                            setTargetGroup(e.target.value);
                            if (selectedInterests.length > 0 || selectedYatra) {
                                updatePreview(selectedInterests, selectedYatra);
                            }
                        }}
                        className="w-full border border-gray-300 p-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-yellow-400"
                    >
                        <option value="Daily Reach">Daily Reach</option>
                        <option value="Do Not Reach">Do Not Reach</option>
                        <option value="Unsubscribed">Unsubscribed</option>
                    </select>
                </div>

                <div className="mb-4">
                    <label className="block font-medium text-gray-700 mb-1">Template (Optional)</label>
                    <select
                        value={selectedTemplate}
                        onChange={(e) => setSelectedTemplate(e.target.value)}
                        className="w-full border border-gray-300 p-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-yellow-400"
                    >
                        <option value="">Select Template</option>
                        {templates.map((template) => (
                            <option key={template.id} value={template.id}>
                                {template.template_name} {template.interest_name ? `- ${template.interest_name}` : ''}
                            </option>
                        ))}
                    </select>
                </div>

                <div className="mb-4">
                    <label className="block font-medium text-gray-700 mb-1">⚡ Quick Preset Messages</label>
                    <select
                        value={selectedPreset}
                        onChange={handlePresetSelect}
                        className="w-full border border-gray-300 p-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-yellow-400"
                    >
                        <option value="">Select a preset message</option>
                        {presetMessages.map((preset) => (
                            <option key={preset.id} value={preset.id}>
                                {preset.name}
                            </option>
                        ))}
                    </select>
                    <p className="text-xs text-gray-400 mt-1">💡 Select a preset to auto-fill the message below</p>
                </div>

                <div className="mb-4">
                    <label className="block font-medium text-gray-700 mb-1">Custom Message</label>
                    <textarea
                        value={customMessage}
                        onChange={(e) => setCustomMessage(e.target.value)}
                        rows="4"
                        className="w-full border border-gray-300 p-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-yellow-400"
                        placeholder="Write your message here... (optional if template selected)"
                    />
                </div>

                <div className="flex flex-wrap gap-4 mb-4">
                    <button
                        type="button"
                        onClick={togglePreview}
                        className="bg-gray-200 hover:bg-gray-300 px-6 py-2 rounded-xl font-semibold transition"
                    >
                        {showPreview ? 'Hide Preview' : 'Show Preview'}
                    </button>
                    {(selectedInterests.length > 0 || selectedYatra) && (
                        <span className="bg-blue-100 text-blue-700 px-4 py-2 rounded-xl">
                            {previewCount} customers will receive this message
                        </span>
                    )}
                </div>

                {showPreview && previewCustomers.length > 0 && (
                    <div className="bg-gray-50 rounded-xl p-4 mb-4 max-h-60 overflow-y-auto">
                        <h3 className="font-medium mb-2">Preview Customers</h3>
                        <div className="space-y-1">
                            {previewCustomers.slice(0, 10).map((customer, index) => (
                                <div key={index} className="text-sm text-gray-600 border-b pb-1">
                                    {customer.customer_name} - {customer.mobile_number}
                                    {customer.interests && ` (${customer.interests.split(',').slice(0, 2).join(', ')})`}
                                </div>
                            ))}
                            {previewCustomers.length > 10 && (
                                <div className="text-sm text-gray-400">
                                    ... and {previewCustomers.length - 10} more
                                </div>
                            )}
                        </div>
                    </div>
                )}

                <div className="flex flex-wrap gap-3">
                    <button
                        onClick={sendBroadcast}
                        disabled={loading || !isConnected || (selectedInterests.length === 0 && !selectedYatra)}
                        className="bg-green-500 hover:bg-green-600 text-white px-8 py-3 rounded-xl font-semibold disabled:opacity-50 transition"
                    >
                        {loading ? 'Sending...' : `📤 Send Broadcast${previewCount > 0 ? ` (${previewCount})` : ''}`}
                    </button>
                    <button
                        onClick={() => {
                            if (!selectedInterests.length && !selectedYatra) {
                                showMessage('Please select interests or yatra first', 'error');
                                return;
                            }
                            if (!customMessage) {
                                showMessage('Please write a message or select a preset', 'error');
                                return;
                            }
                            sendBroadcast();
                        }}
                        disabled={loading || !isConnected || (selectedInterests.length === 0 && !selectedYatra) || !customMessage}
                        className="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-xl font-semibold disabled:opacity-50 transition"
                    >
                        🚀 One-Click Send
                    </button>
                    {previewCount > 0 && (
                        <span className="text-sm text-gray-500 self-center">
                            📊 {previewCount} customers selected
                        </span>
                    )}
                </div>
            </div>

            <div className="bg-white rounded-2xl shadow-lg border border-gray-200 p-6 mb-6">
                <div className="flex justify-between items-center mb-4">
                    <h3 className="text-lg font-bold text-gray-800">👥 Team Activity (Last 7 Days)</h3>
                    <button
                        onClick={loadMessageLogs}
                        className="text-sm text-blue-500 hover:text-blue-700"
                    >
                        🔄 Refresh
                    </button>
                </div>
                
                {messageLogs.length === 0 ? (
                    <p className="text-gray-500 text-center py-4">No messages sent yet</p>
                ) : (
                    <div className="overflow-x-auto">
                        <table className="w-full">
                            <thead className="bg-gray-50">
                                <tr>
                                    <th className="p-3 text-left text-sm font-medium text-gray-600">Team Member</th>
                                    <th className="p-3 text-left text-sm font-medium text-gray-600">Total Sent</th>
                                    <th className="p-3 text-left text-sm font-medium text-gray-600">Status</th>
                                    <th className="p-3 text-left text-sm font-medium text-gray-600">Last Sent</th>
                                </tr>
                            </thead>
                            <tbody className="divide-y divide-gray-100">
                                {Object.entries(
                                    messageLogs.reduce((acc, log) => {
                                        const name = log.team_member || 'Unknown';
                                        if (!acc[name]) {
                                            acc[name] = { total: 0, sent: 0, failed: 0, last: null };
                                        }
                                        acc[name].total++;
                                        if (log.status === 'Sent') acc[name].sent++;
                                        if (log.status === 'Failed') acc[name].failed++;
                                        if (!acc[name].last || new Date(log.sent_at) > new Date(acc[name].last)) {
                                            acc[name].last = log.sent_at;
                                        }
                                        return acc;
                                    }, {})
                                ).map(([name, stats]) => (
                                    <tr key={name} className="hover:bg-gray-50">
                                        <td className="p-3 text-sm font-medium text-gray-800">{name}</td>
                                        <td className="p-3 text-sm text-gray-600">{stats.total}</td>
                                        <td className="p-3">
                                            <span className="text-sm text-green-600">✅ {stats.sent}</span>
                                            {stats.failed > 0 && (
                                                <span className="text-sm text-red-600 ml-2">❌ {stats.failed}</span>
                                            )}
                                        </td>
                                        <td className="p-3 text-sm text-gray-500">
                                            {stats.last ? new Date(stats.last).toLocaleString() : 'Never'}
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                )}
            </div>

            <div className="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden mb-6">
                <div className="p-4 border-b bg-gray-50">
                    <h2 className="font-bold text-gray-800">📜 Message Logs</h2>
                </div>
                <div className="overflow-x-auto max-h-64 overflow-y-auto">
                    <table className="w-full">
                        <thead className="bg-gray-700 text-white sticky top-0">
                            <tr>
                                <th className="p-3 text-left text-sm">#</th>
                                <th className="p-3 text-left text-sm">Customer</th>
                                <th className="p-3 text-left text-sm">Phone</th>
                                <th className="p-3 text-left text-sm">Team Member</th>
                                <th className="p-3 text-left text-sm">Status</th>
                                <th className="p-3 text-left text-sm">Sent At</th>
                            </tr>
                        </thead>
                        <tbody className="divide-y divide-gray-100">
                            {messageLogs.length === 0 ? (
                                <tr>
                                    <td colSpan="6" className="px-4 py-8 text-center text-gray-500">
                                        No messages sent yet
                                    </td>
                                </tr>
                            ) : (
                                messageLogs.slice(0, 20).map((log, index) => (
                                    <tr key={log.id || index} className="hover:bg-gray-50">
                                        <td className="p-3 text-sm text-gray-500">{index + 1}</td>
                                        <td className="p-3 text-sm font-medium text-gray-800">
                                            {log.customer_name || 'Unknown'}
                                        </td>
                                        <td className="p-3 text-sm text-gray-600">{log.mobile_number}</td>
                                        <td className="p-3 text-sm text-gray-600">
                                            {log.team_member || 'Unknown'}
                                        </td>
                                        <td className="p-3">
                                            <span className={`px-2 py-1 rounded-full text-xs ${getStatusColor(log.status)}`}>
                                                {log.status || 'Sent'}
                                            </span>
                                        </td>
                                        <td className="p-3 text-sm text-gray-500">
                                            {new Date(log.sent_at).toLocaleString()}
                                        </td>
                                    </tr>
                                ))
                            )}
                        </tbody>
                    </table>
                </div>
            </div>

            <div className="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden">
                <div className="p-4 border-b bg-gray-50">
                    <h2 className="font-bold text-gray-800">📋 WhatsApp Sessions</h2>
                </div>
                <div className="overflow-x-auto">
                    <table className="w-full">
                        <thead className="bg-gray-800 text-white">
                            <tr>
                                <th className="p-3 text-left text-sm">#</th>
                                <th className="p-3 text-left text-sm">Member</th>
                                <th className="p-3 text-left text-sm">WhatsApp Number</th>
                                <th className="p-3 text-left text-sm">Status</th>
                                <th className="p-3 text-left text-sm">Created</th>
                            </tr>
                        </thead>
                        <tbody className="divide-y divide-gray-100">
                            {sessions.length === 0 ? (
                                <tr>
                                    <td colSpan="5" className="px-4 py-8 text-center text-gray-500">
                                        No WhatsApp sessions yet
                                    </td>
                                </tr>
                            ) : (
                                sessions.map((session, index) => (
                                    <tr key={session.id} className="hover:bg-gray-50">
                                        <td className="px-4 py-3 text-sm text-gray-500">{index + 1}</td>
                                        <td className="px-4 py-3 text-sm font-medium text-gray-800">
                                            {session.member_name || 'Unknown'}
                                        </td>
                                        <td className="px-4 py-3 text-sm text-gray-600">{session.whatsapp_number}</td>
                                        <td className="px-4 py-3 text-sm">
                                            <span className={`px-2 py-1 rounded-full text-xs ${
                                                session.is_verified 
                                                    ? 'bg-green-100 text-green-700' 
                                                    : 'bg-yellow-100 text-yellow-700'
                                            }`}>
                                                {session.is_verified ? '✅ Verified' : '⏳ Pending'}
                                            </span>
                                        </td>
                                        <td className="px-4 py-3 text-sm text-gray-500">
                                            {new Date(session.created_at).toLocaleDateString()}
                                        </td>
                                    </tr>
                                ))
                            )}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    );
};

export default BroadcastPage;
